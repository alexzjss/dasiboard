# ==================================
# DaSIboard - Variáveis de Ambiente
# ==================================

# SERVIDOR
# Porta em que o servidor Express rodará
PORT=3000

# Ambiente da aplicação (development/production)
NODE_ENV=development

# ==================================
# JWT - JSON Web Token
# ==================================

# Chave secreta para assinar JWT (MUDE EM PRODUÇÃO!)
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_super_segura_aqui_mude_em_producao

# Tempo de expiração do token
# Formatos aceitos: "7d" (dias), "24h" (horas), "1800s" (segundos)
JWT_EXPIRE=7d

# ==================================
# BANCO DE DADOS
# ==================================

# Caminho do arquivo SQLite
DB_PATH=./db/dasiboard.db

# ==================================
# CORS - Cross Origin Requests
# ==================================

# Origem permitida para requisições CORS
# Para produção, defina para seu domínio específico
CORS_ORIGIN=http://localhost:3000

# ==================================
# LOGGING (opcional)
# ==================================

# Nível de log (info, warn, error, debug)
LOG_LEVEL=info

# ==================================
# EMAIL (para futuro)
# ==================================

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=seu_email@example.com
# SMTP_PASS=sua_senha_email

# ==================================
# RATE LIMITING (para futuro)
# ==================================

# RATE_LIMIT_WINDOW=15m
# RATE_LIMIT_MAX_REQUESTS=100

# ==================================
# NOTAS IMPORTANTES
# ==================================

# 1. GERAR JWT_SECRET SEGURA:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. EM PRODUÇÃO:
#    - Mude NODE_ENV para "production"
#    - Use JWT_SECRET muito forte
#    - Configure CORS_ORIGIN para seu domínio
#    - Use .env.local (não commitar)
#
# 3. SEGURANÇA:
#    - Nunca commite este arquivo na produção real
#    - Guarde JWT_SECRET em local seguro (ex: AWS Secrets Manager)
#    - Revise regularmente
